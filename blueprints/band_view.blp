using Gtk 4.0;

template $BandView : Box {
  vexpand: true;
  hexpand: true;

  ScrolledWindow {
    vexpand: true;
    hexpand: true;

    FlowBox band_spot_cards {
      column-spacing: 6;
      row-spacing: 12;
      selection-mode: none;
      max-children-per-line: 4;
      homogeneous: false;
    }
  }
}