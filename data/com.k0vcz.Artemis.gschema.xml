<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
	<schema id="com.k0vcz.Artemis" path="/com/k0vcz/Artemis/" gettext-domain="com.k0vcz.Artemis">
        <key name="callsign" type="s">
        <default>""</default>
        <summary>User callsign</summary>
        <description>Your amateur radio callsign.</description>
        </key>

        <key name="location" type="s">
        <default>""</default>
        <summary>Grid Square</summary>
        <description>Your station location or QTH.</description>
        </key>

        <key name="spot-message" type="s">
        <default>""</default>
        <summary>Spot message</summary>
        <description>Default spot message to use when posting.</description>
        </key>

        <key name="update-interval" type="i">
        <default>60</default>
        <summary>Update interval</summary>
        <description>How often to refresh spots, in seconds.</description>
        <range min="60" max="3600"/>
        </key>

        <key name="default-band" type="s">
        <default>"All"</default>
        <summary>Default band</summary>
        <description>The default frequency band (in meters).</description>
        <choices>
            <choice value="All"/>
            <choice value="160m"/>
            <choice value="80m"/>
            <choice value="60m"/>
            <choice value="40m"/>
            <choice value="30m"/>
            <choice value="20m"/>
            <choice value="17m"/>
            <choice value="15m"/>
            <choice value="12m"/>
            <choice value="10m"/>
            <choice value="6m"/>
            <choice value="2m"/>
            <choice value="70cm"/>
        </choices>
        </key>

        <key name="default-mode" type="s">
        <default>"All"</default>
        <summary>Default mode</summary>
        <description>The default operating mode.</description>
        <choices>
            <choice value="All"/>
            <choice value="SSB"/>
            <choice value="CW"/>
            <choice value="FT8"/>
            <choice value="FT4"/>
            <choice value="FM"/>
            <choice value="AM"/>
            <choice value="RTTY"/>
            <choice value="JT65"/>
        </choices>
        </key>

        <key name="qrz-api-key" type="s">
        <default>""</default>
        <summary>QRZ API key</summary>
        <description>API key for QRZ.com lookups.</description>
        </key>

        <!-- Radio Settings -->
        <key name="radio-connection-type" type="s">
        <default>"none"</default>
        <summary>Radio connection type</summary>
        <description>How to connect to the radio (none, serial/USB, network).</description>
        <choices>
            <choice value="none"/>
            <choice value="serial"/>
            <choice value="network"/>
        </choices>
        </key>

        <key name="radio-model" type="i">
        <default>1</default>
        <summary>Radio model ID</summary>
        <description>Hamlib radio model ID number.</description>
        </key>

        <key name="radio-device" type="s">
        <default>"/dev/ttyUSB0"</default>
        <summary>Radio device path</summary>
        <description>Device path for serial/USB connection (e.g., /dev/ttyUSB0 or COM3).</description>
        </key>

        <key name="radio-network-host" type="s">
        <default>"localhost"</default>
        <summary>Network host</summary>
        <description>Hostname or IP address for network connection.</description>
        </key>

        <key name="radio-network-port" type="i">
        <default>4532</default>
        <summary>Network port</summary>
        <description>Port number for network connection.</description>
        <range min="1" max="65535"/>
        </key>

        <key name="radio-baud-rate" type="i">
        <default>9600</default>
        <summary>Serial baud rate</summary>
        <description>Baud rate for serial connection.</description>
        </key>

        <key name="radio-data-bits" type="i">
        <default>0</default>
        <summary>Serial data bits</summary>
        <description>Data bits for serial connection.</description>
        </key>

        <key name="radio-stop-bits" type="i">
        <default>0</default>
        <summary>Serial stop bits</summary>
        <description>Stop bits for serial connection.</description>
        </key>

        <key name="radio-hardware-handshake" type="i">
        <default>0</default>
        <summary>Serial port handshake</summary>
        <description></description>
        </key>

        <key name="hide-older-than" type="i">
        <default>30</default>
        <summary>Hide Stale</summary>
        <description>Hide parks that haven't had an update (in minutes)</description>
        </key>

        <key name="highlight-unhunted-parks" type="b">
        <default>true</default>
        <summary>Highlight unhunted parks</summary>
        <description>Highlight spot cards for parks you haven't hunted before.</description>
        </key>

        <key name="hide-qrt" type="b">
        <default>false</default>
        <summary>Hide QRT</summary>
        <description>Hide stations that have marked themselves QRT</description>
        </key>

        <key name="hide-hunted" type="b">
        <default>false</default>
        <summary>Hide Hunted</summary>
        <description>Hide parks you've hunted today</description>
        </key>

        <key name="show-map-scale" type="b">
        <default>true</default>
        <summary>Show Map Scale</summary>
        <description>Use metric units for distance calculations and elsewhere in the app</description>
        </key>

        <key name="use-metric" type="b">
        <default>false</default>
        <summary>Metric Units</summary>
        <description>Use metric units for distance calculations and elsewhere in the app</description>
        </key>

        <key name="enable-logging" type="b">
        <default>false</default>
        <summary>Enable automatic logging</summary>
        <description>Automatically log QSOs when spotting.</description>
        </key>
	</schema>
</schemalist>
