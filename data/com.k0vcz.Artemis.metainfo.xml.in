  <!-- Applications should set a brand color in both light and dark variants like so -->
  <branding>
    <color type="primary" scheme_preference="light">#1f5ab4</color>
    <color type="primary" scheme_preference="dark">#545454</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image type="source">https://raw.githubusercontent.com/jaybaird/artemis-vala/main/screenshots/main-window.png</image>
      <caption>Main spot hunting view with filters and live cards</caption>
    </screenshot>
    <screenshot>
      <image type="source">https://raw.githubusercontent.com/jaybaird/artemis-vala/main/screenshots/map-view.png</image>
      <caption>Map view showing current park activity and station context</caption>
    </screenshot>
